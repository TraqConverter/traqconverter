# ============================================================
# TraqConverter — environment template
# Copy to `.env` and fill in real values. The keys with no default
# in app/config.py are required for the FastAPI app to even start.
# ============================================================

# --- App ---
app_name=TraqConverter
environment=development

# --- Database ---
# Postgres connection string used by SQLAlchemy + Alembic.
database_url=postgresql+psycopg2://user:password@localhost:5432/traqconverter

# --- Security ---
# Generate with `openssl rand -hex 32`. Rotate it and every JWT is invalidated.
secret_key=replace-me-with-a-32-byte-random-secret
algorithm=HS256
access_token_expire_minutes=60

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Stripe ---
stripe_secret_key=sk_test_...
stripe_publishable_key=pk_test_...
stripe_webhook_secret=whsec_...

# --- Stripe pricing (from your Stripe dashboard's Products page) ---
# Required: Pro. Optional: Basic.
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BASIC=price_...

# --- Stripe redirect URLs (the success URL gets ?session_id appended automatically) ---
STRIPE_SUCCESS_URL=http://localhost:3000/success
STRIPE_CANCEL_URL=http://localhost:3000/cancel

# --- Credit pricing (cents per credit for one-time top-ups) ---
CREDIT_PRICE_CENTS=100

# --- AWS ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1

# --- Storage ---
S3_BUCKET_NAME=traqconverter-uploads

# --- Queue ---
SQS_QUEUE_URL=https://sqs.eu-west-1.amazonaws.com/000000000000/traqconverter-jobs

# --- OCR ---
# Path to the tesseract binary. Auto-detected on Linux/macOS; set this
# only if you're on Windows or have a non-default install.
# TESSERACT_CMD=C:\\Program Files\\Tesseract-OCR\\tesseract.exe
