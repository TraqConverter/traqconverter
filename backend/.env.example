# ============================================================
# TraqConverter backend — env template
# Copy to `.env` and fill in real values.
# ============================================================

# --- App ---
app_name=TraqConverter
environment=production
secret_key=change-me-to-a-32-byte-random-string
algorithm=HS256
access_token_expire_minutes=10080

# --- Database (Supabase Postgres) ---
# Supabase dashboard → Project Settings → Database → Connection string.
# Use the "Transaction" pooler URL for production (port 6543).
database_url=postgresql+psycopg2://postgres.<project-ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# --- CORS ---
# Comma-separated origins allowed to call the API. In production set
# this to your Vercel deployment URL.
CORS_ORIGINS=http://localhost:3000

# --- OpenAI (translation LLM) ---
OPENAI_API_KEY=sk-...

# --- Anthropic (image OCR — recommended) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_VISION_MODEL=claude-sonnet-4-6

# --- Stripe ---
stripe_secret_key=sk_test_or_live_...
stripe_publishable_key=pk_test_or_live_...
stripe_webhook_secret=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_CREDITS_10=price_...
STRIPE_PRICE_CREDITS_25=price_...
STRIPE_PRICE_CREDITS_50=price_...
STRIPE_SUCCESS_URL=https://your-vercel-domain.vercel.app/success
STRIPE_CANCEL_URL=https://your-vercel-domain.vercel.app/cancel
CREDIT_PRICE_CENTS=100

# --- Supabase Storage (S3-compatible) ---
# Supabase dashboard → Project Settings → Storage → S3 access keys.
# Leaving SUPABASE_S3_ENDPOINT blank falls back to real AWS S3.
SUPABASE_S3_ENDPOINT=https://<project-ref>.supabase.co/storage/v1/s3
SUPABASE_S3_ACCESS_KEY=...
SUPABASE_S3_SECRET_KEY=...
SUPABASE_S3_REGION=us-east-1
S3_BUCKET_NAME=traqconverter

# --- Sentry (optional) ---
# SENTRY_DSN=https://...@sentry.io/...
# SENTRY_TRACES_SAMPLE_RATE=0.1

# --- Company logo (optional global fallback when a user hasn't uploaded one) ---
# COMPANY_LOGO_PATH=/app/static/default_logo.png

# --- OCR ---
# Path to the tesseract binary. Auto-detected on Linux/macOS; set this
# only if you're on Windows or have a non-default install.
# TESSERACT_CMD=C:\\Program Files\\Tesseract-OCR\\tesseract.exe

# ============================================================
# LEGACY AWS (only needed if you're still on S3 / SQS — leave blank
# when using Supabase Storage + the Postgres job queue).
# ============================================================
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# SQS_QUEUE_URL=
